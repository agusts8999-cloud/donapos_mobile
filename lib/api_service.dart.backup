  Future<void> syncDiscounts() async {
      final baseUrl = await getBaseUrl();
      final headers = await _getHeaders();
      final prefs = await SharedPreferences.getInstance();
      String log = "Sync Start: ${DateTime.now()}\n";
      
      try {
          final url = '$baseUrl/connector/api/discount';
          log += "URL: $url\n";
          final response = await http.get(Uri.parse(url), headers: headers);
          
          if (response.statusCode == 200) {
              final data = json.decode(response.body);
              final List discounts = data['data'] ?? [];
              log += "Data received: ${discounts.length} items\n";
              
              await DatabaseHelper.instance.clearDiscounts();
              for (var d in discounts) {
                  int dId = int.tryParse(d['id'].toString()) ?? 0;
                  log += "- Processing ID $dId: ${d['name']}\n";
                  
                  await DatabaseHelper.instance.insertDiscount({
                      'id': dId,
                      'name': d['name'],
                      'type': d['discount_type'],
                      'amount': double.tryParse(d['discount_amount'].toString()) ?? 0.0,
                      'priority': int.tryParse(d['priority'].toString()) ?? 0,
                      'starts_at': d['starts_at'],
                      'ends_at': d['ends_at'],
                      'is_active': 1,
                      'brand_id': d['brand_id'],
                      'category_id': d['category_id'],
                      'spg': d['spg']?.toString()
                  });
                  
                  if (d['variations'] != null) {
                      for (var v in d['variations']) {
                          int vId = int.tryParse(v['id'].toString()) ?? 0;
                          await DatabaseHelper.instance.insertDiscountVariation(dId, vId); 
                      }
                  }
              }
              log += "Sync Success.\n";
          } else {
              log += "HTTP Error: ${response.statusCode}\nBody: ${response.body}\n";
          }
      } catch (e) {
          log += "Exception: $e\n";
      }
      
      await prefs.setString('last_sync_log', log);
      print(log);
  }

  Future<void> syncProducts({bool includeImages = true}) async {
    final baseUrl = await getBaseUrl();
    final locationId = await getLocationId();
    final headers = await _getHeaders();
    if (headers['Authorization'] == 'Bearer null') return;

    try {
      // Fetch products with selling_price_group=1 to get group prices
      final response = await http.get(Uri.parse('$baseUrl/connector/api/product?location_id=$locationId&selling_price_group=1'), headers: headers);

      if (response.statusCode == 200) {
        final data = json.decode(response.body);
        final List products = data['data'];

        await DatabaseHelper.instance.clearProducts();
        await DatabaseHelper.instance.clearVariationGroupPrices();

        for (var p in products) {
            double price = 0.0;
            int? variationId;
            
            // Extract Main Price & Variation ID
            List pVars = p['product_variations'] ?? [];
            if (pVars.isNotEmpty) {
                List vars = pVars[0]['variations'] ?? [];
                if (vars.isNotEmpty) {
                    var v = vars[0];
                    price = double.tryParse(v['sell_price_inc_tax'].toString()) ?? 0.0;
                    variationId = v['id'];
                    
                    // Parse Group Prices
                    List groupPrices = v['group_prices'] ?? v['selling_price_group'] ?? [];
                    
                    for (var gp in groupPrices) {
                        await DatabaseHelper.instance.insertVariationGroupPrice({
                            'variation_id': variationId,
                            'price_group_id': gp['price_group_id'],
                            'price': double.tryParse(gp['price_inc_tax'].toString()) ?? 0.0
                        });
                    }
                }
            }
            
            int storageId = (p['type'] == 'single' && variationId != null) ? variationId : p['id'];
            if (variationId != null) storageId = variationId;

            int? catId = int.tryParse(p['category_id']?.toString() ?? '');
            if (catId == null && p['category'] != null) {
                catId = int.tryParse(p['category']['id']?.toString() ?? '');
            }

            int? brandId = int.tryParse(p['brand_id']?.toString() ?? '');
            if (brandId == null && p['brand'] != null) {
                brandId = int.tryParse(p['brand']['id']?.toString() ?? '');
            }

            await DatabaseHelper.instance.insertProduct({
              'id': storageId, 
              'parent_id': p['id'],
              'name': p['name'],
              'price_dinein': price,
              'price_takeaway': price, 
              'price_online': price,
              'category_id': catId,
              'brand_id': brandId,
              'image_url': includeImages ? p['image_url'] : null
            });
        }
        print('[API] Synced ${products.length} products with categories.');
      }
    } catch (e) {
      print('Sync Products Error: $e');
    }
  }

  
  Future<void> syncProductImages() async {
      await syncProducts(includeImages: true);
  }
  
  Future<void> syncAll() async {
      await syncBusinessDetails(); // New: Fetch Location Name
      await syncUsers();
      await syncTypesOfService(); // New
      await syncCategories();
      await syncTaxes(); // New
      await syncDiscounts(); // New
      await syncProducts();
      
      final prefs = await SharedPreferences.getInstance();
      await prefs.setString('last_sync_time', DateTime.now().toIso8601String());
  }

  Future<int> syncTransactions() async {
    final baseUrl = await getBaseUrl();
    final locationId = await getLocationId();
    final headers = await _getHeaders();
    if (headers['Authorization'] == 'Bearer null') {
        print('Sync TX aborted: No Auth Header');
        return 0;
    }

    int syncedCount = 0;
    final unsynced = await DatabaseHelper.instance.getUnsyncedTransactions();
    print('Sync TX: Found ${unsynced.length} unsynced transactions');

    for (var tx in unsynced) {
      try {
        final items = await DatabaseHelper.instance.getTransactionItems(tx['id']);
        print('Sync TX: Processing ID ${tx['id']} with ${items.length} items');
        
        final List<Map<String, dynamic>> productsPayload = [];
        for (var i in items) {
           final p = await DatabaseHelper.instance.getProductById(i['product_id']);
           productsPayload.add({
              'product_id': p?['parent_id'] ?? i['product_id'],
              'variation_id': i['product_id'], 
              'quantity': i['qty'],
              'unit_price': i['price'],
              'note': i['note']
           });
        }

        // Find types_of_service_id
        int? serviceTypeId;
        if (tx['sale_type'] != null) {
            final allServices = await DatabaseHelper.instance.getAllTypesOfService();
            // Match name (case insensitive)
            String st = tx['sale_type'].toString().toLowerCase().replaceAll('-', ' ');
            for (var s in allServices) {
                if (s['name'].toString().toLowerCase().contains(st)) {
                    serviceTypeId = s['id'];
                    break;
                }
            }
        }

        final transactionDateStr = tx['created_at'] != null 
            ? DateFormat('yyyy-MM-dd HH:mm:ss').format(DateTime.parse(tx['created_at']))
            : DateFormat('yyyy-MM-dd HH:mm:ss').format(DateTime.now());

        final payload = {
          'sells': [{
            'status': 'final',
            'contact_id': 1, 
            'transaction_date': transactionDateStr,
            'location_id': locationId, 
            'final_total': tx['total'],
            'discount_amount': tx['discount'],
            'discount_type': 'fixed',
            'table_id': tx['res_table_id'],
            'types_of_service_id': serviceTypeId,
            'payments': [{'amount': tx['total'], 'method': 'cash'}],
            'products': productsPayload
          }]
        };

        print('Sync TX [PAYLOAD]: ${json.encode(payload)}');

        final response = await http.post(
          Uri.parse('$baseUrl/connector/api/sell'),
          headers: headers,
          body: json.encode(payload),
        );

        print('Sync TX [RESPONSE]: ${response.statusCode} - ${response.body}');
        if (response.statusCode == 200 || response.statusCode == 201) {
          await DatabaseHelper.instance.markTransactionSynced(tx['id']);
          syncedCount++;
        } else {
          // If server returns error, we might want to know why
          final errorData = json.decode(response.body);
          throw Exception('Server Error ${response.statusCode}: ${errorData['message'] ?? response.body}');
        }
      } catch (e) {
        print('Sync TX Exception: $e');
        rethrow; // Re-throw to show error in UI
      }
    }
    return syncedCount;
  }

  Future<int> getUnsyncedCount() async {
      final unsynced = await DatabaseHelper.instance.getUnsyncedTransactions();
      return unsynced.length;
  }

  // --- Reports & Closing ---
  Future<Map<String, dynamic>> getKasirSummary() async {
    final baseUrl = await getBaseUrl();
    final headers = await _getHeaders();
    final response = await http.get(Uri.parse('$baseUrl/connector/api/report/kasir-summary'), headers: headers);

    if (response.statusCode == 200) {
      return json.decode(response.body);
    } else {
      throw Exception('Failed to load Kasir Summary: ${response.body}');
    }
  }

  Future<Map<String, dynamic>> getZReport(String date) async {
    final baseUrl = await getBaseUrl();
    final headers = await _getHeaders();
    final response = await http.get(Uri.parse('$baseUrl/connector/api/report/z-report?tanggal=$date'), headers: headers);

    if (response.statusCode == 200) {
